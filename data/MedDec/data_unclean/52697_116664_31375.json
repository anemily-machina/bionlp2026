MT_131"}, {"decision": "narcotic pain medicine", "category": "Category 5: Drug related", "start_offset": "11405", "end_offset": "11427", "annotation_id": "MT_132"}, {"decision": "constipation", "category": "Category 3: Defining problem", "start_offset": "11438", "end_offset": "11450", "annotation_id": "MT_133"}, {"decision": "Increase your intake of fluids and fiber, as narcotic pain medicine can cause constipation.", "category": "Category 9: Advice and precaution", "start_offset": 11360, "end_offset": 11451, "annotation_id": "MT_134"}, {"decision": "Docusate (Colace)", "category": "Category 5: Drug related", "start_offset": "11526", "end_offset": "11543", "annotation_id": "MT_135"}, {"decision": "We generally recommend taking an over the counter stool softener, such as Docusate (Colace) while taking narcotic pain medication.", "category": "Category 9: Advice and precaution", "start_offset": 11452, "end_offset": 11582, "annotation_id": "MT_136"}, {"decision": "Docusate (Colace) while taking narcotic pain medication.", "category": "Category 5: Drug related", "start_offset": 11526, "end_offset": 11582, "annotation_id": "MT_137"}, {"decision": "Keppra (Levetiracetam)", "category": "Category 5: Drug related", "start_offset": "11618", "end_offset": "11640", "annotation_id": "MT_138"}, {"decision": "you will not require blood work monitoring.", "category": "Category 9: Advice and precaution", "start_offset": "11642", "end_offset": "11685", "annotation_id": "MT_139"}, {"decision": "Clearance to drive and return to work will be addressed at your post-operative office visit.", "category": "Category 9: Advice and precaution", "start_offset": "11693", "end_offset": "11785", "annotation_id": "MT_140"}, {"decision": "to use your incentive spirometer ", "category": "Category 6: Therapeutic procedure related", "start_offset": "11815", "end_offset": "11848", "annotation_id": "MT_141"}, {"decision": "Make sure to continue to use your incentive spirometer while at home, unless you have been instructed not to.", "category": "Category 9: Advice and precaution", "start_offset": 11793, "end_offset": 11902, "annotation_id": "MT_142"}, {"decision": "CALL YOUR SURGEON IMMEDIATELY IF YOU EXPERIENCE ANY OF THE FOLLOWING  ??????\tNew onset of tremors or seizures. ??????\tAny confusion or change in mental status.", "category": "Category 9: Advice and precaution", "start_offset": "11904", "end_offset": "12063", "annotation_id": "MT_143"}, {"decision": "Any numbness, tingling, weakness in your extremities. ??????\tPain or headache that is continually increasing, or not relieved by pain medication.", "category": "Category 9: Advice and precaution", "start_offset": "12071", "end_offset": "12216", "annotation_id": "MT_144"}, {"decision": "Any signs of infection at the wound site: redness, swelling, tenderness, or drainage. ??????\tFever greater than or equal to 101?????? F.", "category": "Category 9: Advice and precaution", "start_offset": "12224", "end_offset": "12360", "annotation_id": "MT_145"}, {"decision": "You will need an appointment in 2 weeks at the Brain [**Hospital 341**] Clinic and please call. Their phone number is [**Telephone/Fax (1) 1844**]. The Brain [**Hospital 341**] Clinic is located on the [**Hospital Ward Name 516**] of [**Hospital1 18**], in the [**Hospital Ward Name 23**] Building, [**Location (un) **].", "category": "Category 9: Advice and precaution", "start_offset": "12428", "end_offset": "12748", "annotation_id": "MT_146"}, {"decision": "Pterygium ", "category": "Category 3: Defining problem", "start_offset": "12815", "end_offset": "12825", "annotation_id": "MT_147"}, {"decision": "Please follow up with Ophthomolgy in [**7-1**] weeks for your Pterygium for evaluation and treatment.", "category": "Category 9: Advice and precaution", "start_offset": 12753, "end_offset": 12854, "annotation_id": "MT_148"}]}