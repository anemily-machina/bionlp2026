52"}, {"decision": "Activity Status: Ambulatory - Independent", "category": "Category 3: Defining problem", "start_offset": 13005, "end_offset": 13046, "annotation_id": "LX_153"}, {"decision": "severe anemia ", "category": "Category 3: Defining problem", "start_offset": 13146, "end_offset": 13160, "annotation_id": "LX_154"}, {"decision": "abnormal tissue in your stomach ", "category": "Category 3: Defining problem", "start_offset": 13195, "end_offset": 13227, "annotation_id": "LX_155"}, {"decision": "endoscopy and cautery", "category": "Category 6: Therapeutic procedure related", "start_offset": 13250, "end_offset": 13271, "annotation_id": "LX_156"}, {"decision": "intravenous iron", "category": "Category 5: Drug related", "start_offset": 13289, "end_offset": 13305, "annotation_id": "LX_157"}, {"decision": "severe iron deficiency anemia", "category": "Category 3: Defining problem", "start_offset": 13322, "end_offset": 13351, "annotation_id": "LX_158"}, {"decision": "You have received a prescription for oral iron twice daily which you should take until your primary care doctor tells you to stop.", "category": "Category 9: Advice and precaution", "start_offset": 13354, "end_offset": 13484, "annotation_id": "LX_159"}, {"decision": "Pantoprazole ", "category": "Category 5: Drug related", "start_offset": 13486, "end_offset": 13499, "annotation_id": "LX_160"}, {"decision": "Pantoprazole has been increased to 40mg twice daily--you have received a prescription for this.  You should take this increased dose for at least 4-6 weeks and can discuss the ultimate duration with your PCP", "category": "Category 9: Advice and precaution", "start_offset": 13486, "end_offset": 13693, "annotation_id": "LX_161"}, {"decision": "coumadin ", "category": "Category 5: Drug related", "start_offset": 13724, "end_offset": 13733, "annotation_id": "LX_162"}, {"decision": "EGD/colonoscopy ", "category": "Category 6: Therapeutic procedure related", "start_offset": 13783, "end_offset": 13799, "annota